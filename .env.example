PORT=3000
NODE_ENV=development

# URL pública (Easypanel). Si está seteada, Swagger la usa como server default.
# PUBLIC_URL=https://backend-backend-js.rt3mm1.easypanel.host

# Logs: por default usa pino-pretty (colored + legible). LOG_PRETTY=false para JSON puro.
# LOG_PRETTY=false

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Token interno para autenticar requests a la API. Se acepta cualquiera de los dos
# en el header Authorization: Bearer (o x-internal-token). INTERNAL_API_KEY es el
# secreto compartido con el Next.js para /api/messages/send; INTERNAL_TOKEN es legacy.
INTERNAL_TOKEN=replace-with-your-internal-token
INTERNAL_API_KEY=replace-with-shared-secret-with-nextjs

# Unipile webhooks
UNIPILE_WEBHOOK_SECRET=
N8N_DEFAULT_HOST=

# Unipile API (DSN + key — usado para enviar mensajes salientes y follow-ups)
UNIPILE_DEFAULT_DSN=
UNIPILE_DEFAULT_API_KEY=

# EvolutionAPI (WhatsApp trial). API_URL/API_KEY para enviar mensajes salientes;
# WEBHOOK_SECRET valida el header Bearer de los webhooks entrantes (lo inyecta el
# dashboard al crear la instancia). Debe matchear el secret configurado en el dashboard.
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_WEBHOOK_SECRET=

# Follow-up cron job
OPENAI_API_KEY=
# Cron schedule (default 14:00 UTC ≈ 11 AM Argentina). Apagar con DISABLE_JOBS=true.
FOLLOW_UP_CRON=0 14 * * *
# Threshold de inactividad. Default 24h.
FOLLOW_UP_INACTIVITY_HOURS=24
# Dry run: genera el mensaje pero no envía ni marca follow_up_sent_at. Útil para piloto.
FOLLOW_UP_DRY_RUN=false
# Tope de envíos por workflow en una corrida. El sobrante se procesa al día siguiente.
FOLLOW_UP_MAX_PER_WORKFLOW=300

# TiendaNube (Nuvemshop). OAuth sin refresh: el access_token NO expira. APP_ID y
# CLIENT_SECRET vienen de la app de partner. REDIRECT_URI debe matchear el registrado
# en la app (= <PUBLIC_URL>/api/tiendanube/oauth/callback). USER_AGENT es obligatorio
# en cada request a la API (formato "App (email)"). El state del OAuth se firma con
# INTERNAL_API_KEY (compartido con el dashboard). DASHBOARD_URL: a dónde volver tras conectar.
TIENDANUBE_APP_ID=
TIENDANUBE_CLIENT_SECRET=
TIENDANUBE_REDIRECT_URI=
TIENDANUBE_USER_AGENT=Tilegra (soporte@tilegra.com)
TIENDANUBE_CACHE_TTL_MINUTES=60
DASHBOARD_URL=https://app.tilegra.com

# Google (Sheets + Calendar + Drive). OAuth por cliente con refresh_token.
# CLIENT_ID/SECRET vienen de Google Cloud Console (OAuth client tipo Web application).
# REDIRECT_URI debe matchear EXACTO el "Authorized redirect URI" registrado en Google
# (= <PUBLIC_URL>/api/google/oauth/callback). El state del OAuth se firma con INTERNAL_API_KEY.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# Email (Resend) — usado por el CRON de ciclo de vida para avisar y notificar cortes.
RESEND_API_KEY=
RESEND_FROM=notificaciones@tilegra.com

# Account lifecycle cron: desconecta canales de trials vencidos (sin avanzar a un
# plan) y de planes con pago vencido, tras la gracia configurada. Manda aviso previo
# + email de corte. Reusa UNIPILE_DEFAULT_* y EVOLUTION_API_* para desconectar.
# Cron schedule (default 13:00 UTC ≈ 10 AM Argentina). Apagar con DISABLE_JOBS=true.
ACCOUNT_LIFECYCLE_CRON=0 13 * * *
# Horas de gracia tras el vencimiento antes de desconectar (y ventana del aviso previo).
ACCOUNT_LIFECYCLE_GRACE_HOURS=24
# Dry run: detecta candidatos y loguea pero no envía emails ni desconecta/borra canales.
ACCOUNT_LIFECYCLE_DRY_RUN=false